---
import ProjectCard from '@/components/project-card.astro'
import type { ProjectFolderGroup } from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'

interface Props {
  group: ProjectFolderGroup
  open?: boolean
}

const { group, open = false } = Astro.props
---

<details
  class="group bg-muted/20 rounded-2xl border"
  data-project-folder
  name="project-folder-groups"
  open={open}
>
  <summary
    data-project-folder-trigger
    class="flex cursor-pointer list-none items-center justify-between gap-4 p-4 [&::-webkit-details-marker]:hidden"
  >
    <div class="flex min-w-0 items-center gap-3">
      <div
        class="bg-background text-muted-foreground flex size-11 shrink-0 items-center justify-center rounded-xl border"
      >
        <Icon name="lucide:folder" class="size-5 group-open:hidden" />
        <Icon
          name="lucide:folder-open"
          class="hidden size-5 group-open:block"
        />
      </div>
      <div class="min-w-0">
        <h3 class="truncate text-lg font-medium">{group.name}</h3>
        <p class="text-muted-foreground text-xs">
          {group.projects.length} 个项目
        </p>
      </div>
    </div>

    <Icon
      name="lucide:chevron-right"
      class="text-muted-foreground size-4 shrink-0 transition-transform duration-200 group-open:rotate-90"
    />
  </summary>

  <div class="border-t px-4 py-4" data-project-folder-panel>
    <div class="flex flex-col gap-4">
      {group.projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</details>
