---
import { cn } from '@/lib/utils'

interface Props {
  date?: string | Date
  class?: string
}

const { date, class: className } = Astro.props

const formattedDate =
  date instanceof Date
    ? Intl.DateTimeFormat('zh-CN', {
        month: '2-digit',
        day: '2-digit',
      }).format(date)
    : (date?.trim() ?? '')
---

<span class={cn('inline', className)}>
  <span
    class="text-foreground/95 rounded-[0.3rem] border-b border-amber-400/28 bg-amber-400/10 px-1 py-[0.04em]"
    style="-webkit-box-decoration-break: clone; box-decoration-break: clone;"
  >
    <slot />
  </span>
  {
    formattedDate && (
      <span class="ml-1 align-super text-[0.72em] tracking-[0.08em] whitespace-nowrap text-amber-300/72">
        补写 {formattedDate}
      </span>
    )
  }
</span>
