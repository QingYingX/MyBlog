---
import { Button } from '@/components/ui/button'
import { THEME_TOGGLE } from '@/consts'
import { Icon } from 'astro-icon/components'
---

<Button
  id="theme-toggle"
  type="button"
  variant="ghost"
  size="icon"
  title="切换主题"
  className="-my-2 -me-2 size-8"
>
  <Icon name="lucide:sun" class="size-4 dark:hidden" />
  <Icon name="lucide:moon" class="absolute hidden size-4 dark:block" />
  <span class="sr-only">切换主题</span>
</Button>

<script is:inline data-astro-rerun>
  ;(() => {
    const theme = (() => {
      const stored = localStorage?.getItem('theme') ?? ''
      if (['dark', 'light'].includes(stored)) return stored
      return window.matchMedia('(prefers-color-scheme: dark)').matches
        ? 'dark'
        : 'light'
    })()

    document.documentElement.setAttribute('data-theme', theme)
    window.localStorage.setItem('theme', theme)
  })()
</script>

<script
  is:inline
  define:vars={{ themeToggleFollowPointer: THEME_TOGGLE.followPointer }}
>
  const THEME_STORAGE_KEY = 'theme'
  const THEME_TOGGLE_SELECTOR = '#theme-toggle'
  const THEME_TRANSITION_DURATION = 820
  const THEME_POINTER_FOLLOW = 0.18
  const THEME_FADE_START = 0.72
  const THEME_SNAPSHOT_ATTRIBUTE = 'data-theme-transition-snapshot'
  const SHOULD_FOLLOW_POINTER = themeToggleFollowPointer

  const themeWindow = window

  function getStoredTheme() {
    const storedTheme = window.localStorage.getItem(THEME_STORAGE_KEY)
    return storedTheme === 'dark' || storedTheme === 'light'
      ? storedTheme
      : null
  }

  function getPreferredTheme() {
    return (
      getStoredTheme() ??
      (window.matchMedia('(prefers-color-scheme: dark)').matches
        ? 'dark'
        : 'light')
    )
  }

  function getCurrentTheme() {
    return document.documentElement.getAttribute('data-theme') === 'dark'
      ? 'dark'
      : 'light'
  }

  function disableThemeTransitions() {
    const root = document.documentElement
    root.classList.add('theme-switching')
    void window.getComputedStyle(root).opacity

    return () => {
      requestAnimationFrame(() => {
        root.classList.remove('theme-switching')
      })
    }
  }

  function applyTheme(theme) {
    document.documentElement.setAttribute('data-theme', theme)
    window.localStorage.setItem(THEME_STORAGE_KEY, theme)
  }

  function applyThemeWithoutTransitions(theme) {
    const restoreTransitions = disableThemeTransitions()
    applyTheme(theme)
    restoreTransitions()
  }

  function syncTheme() {
    applyThemeWithoutTransitions(getPreferredTheme())
  }

  function applyThemeWithoutAnimation(theme) {
    applyThemeWithoutTransitions(theme)
  }

  function getButtonCenter(button) {
    const { left, top, width, height } = button.getBoundingClientRect()
    return {
      x: left + width / 2,
      y: top + height / 2,
    }
  }

  function getPointerOrigin(button, event) {
    if (event.clientX !== 0 || event.clientY !== 0) {
      return { x: event.clientX, y: event.clientY }
    }

    return getButtonCenter(button)
  }

  function getViewportCenter() {
    return {
      x: window.innerWidth / 2,
      y: window.innerHeight / 2,
    }
  }

  function getLastPointer() {
    return themeWindow.__themeLastPointer ?? getViewportCenter()
  }

  function setLastPointer(pointer) {
    themeWindow.__themeLastPointer = pointer
  }

  function getRevealRadius(pointer) {
    return Math.hypot(
      Math.max(pointer.x, window.innerWidth - pointer.x),
      Math.max(pointer.y, window.innerHeight - pointer.y),
    )
  }

  function lerp(start, end, amount) {
    return start + (end - start) * amount
  }

  function clamp(value, min, max) {
    return Math.min(max, Math.max(min, value))
  }

  function easeInOutCubic(value) {
    if (value < 0.5) return 4 * value * value * value
    return 1 - Math.pow(-2 * value + 2, 3) / 2
  }

  function canAnimateThemeTransition() {
    return !window.matchMedia('(prefers-reduced-motion: reduce)').matches
  }

  function createThemeSnapshot(theme) {
    const snapshot = document.createElement('div')
    const snapshotContent = document.createElement('div')

    snapshot.setAttribute(THEME_SNAPSHOT_ATTRIBUTE, '')
    snapshot.setAttribute('aria-hidden', 'true')

    const rootStyles = window.getComputedStyle(document.documentElement)

    for (const propertyName of rootStyles) {
      if (!propertyName.startsWith('--')) continue

      snapshot.style.setProperty(
        propertyName,
        rootStyles.getPropertyValue(propertyName),
      )
    }

    snapshot.style.colorScheme = rootStyles.colorScheme
    snapshot.style.color = rootStyles.color
    snapshot.style.backgroundColor = rootStyles.backgroundColor
    snapshot.style.font = rootStyles.font
    snapshot.style.lineHeight = rootStyles.lineHeight

    snapshotContent.className = document.body.className
    snapshotContent.innerHTML = document.body.innerHTML
    snapshotContent.setAttribute('data-theme', theme)
    snapshotContent.style.transform = `translate(${-window.scrollX}px, ${-window.scrollY}px)`
    snapshotContent.style.width = '100%'
    snapshot.append(snapshotContent)

    document.body.append(snapshot)
    return snapshot
  }

  function animateSnapshotReveal(
    snapshot,
    origin,
    followPointer,
    lockedPointer,
  ) {
    let currentPointer = origin

    return new Promise((resolve) => {
      const startedAt = performance.now()

      const step = (now) => {
        const progress = clamp(
          (now - startedAt) / THEME_TRANSITION_DURATION,
          0,
          1,
        )
        const eased = easeInOutCubic(progress)
        const target = followPointer ? getLastPointer() : lockedPointer

        currentPointer = {
          x: lerp(currentPointer.x, target.x, THEME_POINTER_FOLLOW),
          y: lerp(currentPointer.y, target.y, THEME_POINTER_FOLLOW),
        }

        const radius = getRevealRadius(currentPointer) * (1 - eased)
        const fadeProgress = clamp(
          (progress - THEME_FADE_START) / (1 - THEME_FADE_START),
          0,
          1,
        )

        snapshot.style.clipPath = `circle(${Math.max(radius, 0)}px at ${currentPointer.x}px ${currentPointer.y}px)`
        snapshot.style.opacity = String(1 - fadeProgress * 0.12)

        if (progress < 1) {
          requestAnimationFrame(step)
          return
        }

        snapshot.style.clipPath = `circle(0px at ${currentPointer.x}px ${currentPointer.y}px)`
        snapshot.style.opacity = '0'
        resolve()
      }

      snapshot.style.clipPath = `circle(${getRevealRadius(currentPointer)}px at ${currentPointer.x}px ${currentPointer.y}px)`
      requestAnimationFrame(step)
    })
  }

  function runThemeTransition(theme, origin, followPointer, lockedPointer) {
    const currentTheme = getCurrentTheme()
    const restoreTransitions = disableThemeTransitions()
    const snapshot = createThemeSnapshot(currentTheme)

    applyTheme(theme)

    animateSnapshotReveal(snapshot, origin, followPointer, lockedPointer)
      .catch(() => {})
      .finally(() => {
        snapshot.remove()
        restoreTransitions()
        themeWindow.__themeTransitionRunning = false
      })
  }

  function handleThemeToggleClick(button, event) {
    if (themeWindow.__themeTransitionRunning) return

    const newTheme = getCurrentTheme() === 'dark' ? 'light' : 'dark'
    if (!canAnimateThemeTransition()) {
      applyThemeWithoutAnimation(newTheme)
      return
    }

    const lockedPointer = getButtonCenter(button)
    const followPointer = SHOULD_FOLLOW_POINTER
    const origin = followPointer
      ? getPointerOrigin(button, event)
      : lockedPointer

    setLastPointer(origin)

    themeWindow.__themeTransitionRunning = true
    runThemeTransition(newTheme, origin, followPointer, lockedPointer)
  }

  function initThemeToggle() {
    if (themeWindow.__themeToggleInitialized) return

    themeWindow.__themeToggleInitialized = true

    setLastPointer(getViewportCenter())

    document.addEventListener('pointermove', (event) => {
      setLastPointer({ x: event.clientX, y: event.clientY })
    })

    document.addEventListener('click', (event) => {
      const target = event.target
      if (!(target instanceof Element)) return

      const button = target.closest(THEME_TOGGLE_SELECTOR)
      if (!(button instanceof HTMLElement)) return

      handleThemeToggleClick(button, event)
    })

    document.addEventListener('astro:after-swap', () => {
      syncTheme()
    })
  }

  initThemeToggle()
</script>
