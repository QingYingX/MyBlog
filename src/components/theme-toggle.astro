---
import { Button } from '@/components/ui/button'
import { THEME_TOGGLE } from '@/config'
import { Icon } from 'astro-icon/components'
---

<Button
  id="theme-toggle"
  type="button"
  variant="ghost"
  size="icon"
  title="切换主题"
  className="-my-2 -me-2 size-8"
>
  <Icon name="lucide:sun" class="size-4 dark:hidden" />
  <Icon name="lucide:moon" class="absolute hidden size-4 dark:block" />
  <span class="sr-only">切换主题</span>
</Button>

<script is:inline data-astro-rerun>
  ;(() => {
    const resolvePreferredTheme = () => {
      const stored = localStorage?.getItem('theme') ?? ''
      if (['dark', 'light'].includes(stored)) return stored
      return window.matchMedia('(prefers-color-scheme: dark)').matches
        ? 'dark'
        : 'light'
    }

    window.__resolvePreferredTheme = resolvePreferredTheme

    const theme = resolvePreferredTheme()

    document.documentElement.setAttribute('data-theme', theme)
    window.localStorage.setItem('theme', theme)
  })()
</script>

<script
  is:inline
  define:vars={{ themeToggleFollowPointer: THEME_TOGGLE.followPointer }}
>
  const THEME_STORAGE_KEY = 'theme'
  const THEME_TOGGLE_SELECTOR = '#theme-toggle'
  const THEME_TRANSITION_DURATION = 820
  const THEME_POINTER_FOLLOW = 0.18
  const THEME_SNAPSHOT_ATTRIBUTE = 'data-theme-transition-snapshot'
  const SHOULD_FOLLOW_POINTER = themeToggleFollowPointer

  const themeWindow = window
  const resolvePreferredTheme =
    themeWindow.__resolvePreferredTheme ??
    (() => {
      const storedTheme = window.localStorage.getItem(THEME_STORAGE_KEY)
      if (storedTheme === 'dark' || storedTheme === 'light') {
        return storedTheme
      }

      return window.matchMedia('(prefers-color-scheme: dark)').matches
        ? 'dark'
        : 'light'
    })

  function getCurrentTheme() {
    return document.documentElement.getAttribute('data-theme') === 'dark'
      ? 'dark'
      : 'light'
  }

  function registerThemeTransitionCleanup(cleanup) {
    let cleanedUp = false

    const finalize = () => {
      if (cleanedUp) return

      cleanedUp = true

      if (themeWindow.__themeTransitionCleanup === finalize) {
        themeWindow.__themeTransitionCleanup = undefined
      }

      themeWindow.__themeTransitionRunning = false
      cleanup()
    }

    themeWindow.__themeTransitionCleanup = finalize
    return finalize
  }

  function cancelRunningThemeTransition() {
    themeWindow.__themeTransitionCleanup?.()
  }

  function disableThemeTransitions() {
    const root = document.documentElement
    root.classList.add('theme-switching')
    void window.getComputedStyle(root).opacity

    return () => {
      requestAnimationFrame(() => {
        root.classList.remove('theme-switching')
      })
    }
  }

  function applyTheme(theme) {
    document.documentElement.setAttribute('data-theme', theme)
    window.localStorage.setItem(THEME_STORAGE_KEY, theme)
  }

  function applyThemeWithoutTransitions(theme) {
    const restoreTransitions = disableThemeTransitions()
    applyTheme(theme)
    restoreTransitions()
  }

  function syncTheme() {
    applyThemeWithoutTransitions(resolvePreferredTheme())
  }

  function getButtonCenter(button) {
    const { left, top, width, height } = button.getBoundingClientRect()
    return {
      x: left + width / 2,
      y: top + height / 2,
    }
  }

  function getPointerOrigin(button, event) {
    if (event.clientX !== 0 || event.clientY !== 0) {
      return { x: event.clientX, y: event.clientY }
    }

    return getButtonCenter(button)
  }

  function getViewportCenter() {
    return {
      x: window.innerWidth / 2,
      y: window.innerHeight / 2,
    }
  }

  function getLastPointer() {
    return themeWindow.__themeLastPointer ?? getViewportCenter()
  }

  function setLastPointer(pointer) {
    themeWindow.__themeLastPointer = pointer
  }

  function getRevealRadius(pointer) {
    return Math.hypot(
      Math.max(pointer.x, window.innerWidth - pointer.x),
      Math.max(pointer.y, window.innerHeight - pointer.y),
    )
  }

  function lerp(start, end, amount) {
    return start + (end - start) * amount
  }

  function clamp(value, min, max) {
    return Math.min(max, Math.max(min, value))
  }

  function easeInOutCubic(value) {
    if (value < 0.5) return 4 * value * value * value
    return 1 - Math.pow(-2 * value + 2, 3) / 2
  }

  function canAnimateThemeTransition() {
    return !window.matchMedia('(prefers-reduced-motion: reduce)').matches
  }

  function canUseViewTransition() {
    return typeof document.startViewTransition === 'function'
  }

  function getThemeTransitionMode(theme) {
    return theme === 'dark' ? 'expand' : 'shrink'
  }

  function createThemeSnapshot(theme) {
    const snapshot = document.createElement('div')
    const snapshotContent = document.createElement('div')

    snapshot.setAttribute(THEME_SNAPSHOT_ATTRIBUTE, '')
    snapshot.setAttribute('aria-hidden', 'true')
    snapshot.setAttribute('data-theme', theme)

    const rootStyles = window.getComputedStyle(document.documentElement)

    for (const propertyName of rootStyles) {
      if (!propertyName.startsWith('--')) continue

      snapshot.style.setProperty(
        propertyName,
        rootStyles.getPropertyValue(propertyName),
      )
    }

    snapshot.style.colorScheme = rootStyles.colorScheme
    snapshot.style.color = rootStyles.color
    snapshot.style.backgroundColor = rootStyles.backgroundColor
    snapshot.style.font = rootStyles.font
    snapshot.style.lineHeight = rootStyles.lineHeight

    snapshotContent.className = document.body.className
    snapshotContent.innerHTML = document.body.innerHTML
    snapshotContent.setAttribute('data-theme', theme)
    snapshotContent.style.transform = `translate(${-window.scrollX}px, ${-window.scrollY}px)`
    snapshotContent.style.width = '100%'
    snapshotContent.querySelectorAll('details[name]').forEach((detail) => {
      detail.removeAttribute('name')
    })
    snapshot.append(snapshotContent)

    document.body.append(snapshot)
    return snapshot
  }

  function applySnapshotMask(snapshot, pointer, radius) {
    const resolvedRadius = Math.max(radius, 0)
    const maskImage = `radial-gradient(circle at ${pointer.x}px ${pointer.y}px, transparent 0 ${resolvedRadius}px, #000 ${resolvedRadius}px 100%)`

    snapshot.style.clipPath = 'inset(0)'
    snapshot.style.webkitMaskImage = maskImage
    snapshot.style.maskImage = maskImage
    snapshot.style.webkitMaskRepeat = 'no-repeat'
    snapshot.style.maskRepeat = 'no-repeat'
  }

  function clearSnapshotMask(snapshot) {
    snapshot.style.webkitMaskImage = ''
    snapshot.style.maskImage = ''
    snapshot.style.webkitMaskRepeat = ''
    snapshot.style.maskRepeat = ''
  }

  function setSnapshotRevealState(snapshot, mode, pointer, radius) {
    if (mode === 'expand') {
      applySnapshotMask(snapshot, pointer, radius)
      return
    }

    clearSnapshotMask(snapshot)
    snapshot.style.clipPath = `circle(${Math.max(radius, 0)}px at ${pointer.x}px ${pointer.y}px)`
  }

  function animateSnapshotReveal(
    snapshot,
    origin,
    followPointer,
    lockedPointer,
    mode,
    transitionState,
  ) {
    let currentPointer = origin

    return new Promise((resolve) => {
      const startedAt = performance.now()

      const step = (now) => {
        if (transitionState.cancelled) {
          resolve()
          return
        }

        const progress = clamp(
          (now - startedAt) / THEME_TRANSITION_DURATION,
          0,
          1,
        )
        const eased = easeInOutCubic(progress)
        const target = followPointer ? getLastPointer() : lockedPointer

        currentPointer = {
          x: lerp(currentPointer.x, target.x, THEME_POINTER_FOLLOW),
          y: lerp(currentPointer.y, target.y, THEME_POINTER_FOLLOW),
        }

        const radius =
          getRevealRadius(currentPointer) *
          (mode === 'expand' ? eased : 1 - eased)

        setSnapshotRevealState(snapshot, mode, currentPointer, radius)
        snapshot.style.opacity = '1'

        if (progress < 1) {
          requestAnimationFrame(step)
          return
        }

        setSnapshotRevealState(
          snapshot,
          mode,
          currentPointer,
          mode === 'expand' ? getRevealRadius(currentPointer) : 0,
        )
        resolve()
      }

      setSnapshotRevealState(
        snapshot,
        mode,
        currentPointer,
        mode === 'expand' ? 0 : getRevealRadius(currentPointer),
      )
      requestAnimationFrame(step)
    })
  }

  function runThemeViewTransition(theme, origin) {
    const transitionMode = getThemeTransitionMode(theme)
    const restoreTransitions = disableThemeTransitions()
    const radius = getRevealRadius(origin)
    const pseudoElement =
      transitionMode === 'expand'
        ? '::view-transition-new(root)'
        : '::view-transition-old(root)'

    let clipAnimation

    const finalize = registerThemeTransitionCleanup(() => {
      clipAnimation?.cancel()
      restoreTransitions()
    })

    try {
      const transition = document.startViewTransition(() => {
        applyTheme(theme)
      })

      transition.ready
        .then(() => {
          if (themeWindow.__themeTransitionCleanup !== finalize) return

          clipAnimation = document.documentElement.animate(
            {
              clipPath:
                transitionMode === 'expand'
                  ? [
                      `circle(0px at ${origin.x}px ${origin.y}px)`,
                      `circle(${radius}px at ${origin.x}px ${origin.y}px)`,
                    ]
                  : [
                      `circle(${radius}px at ${origin.x}px ${origin.y}px)`,
                      `circle(0px at ${origin.x}px ${origin.y}px)`,
                    ],
            },
            {
              duration: THEME_TRANSITION_DURATION,
              easing: 'cubic-bezier(0.65, 0, 0.35, 1)',
              fill: 'both',
              pseudoElement,
            },
          )

          return clipAnimation.finished
        })
        .catch(() => {})
        .finally(() => {
          transition.finished.catch(() => {}).finally(finalize)
        })
    } catch {
      applyTheme(theme)
      finalize()
    }
  }

  function runThemeTransition(theme, origin, followPointer, lockedPointer) {
    const currentTheme = getCurrentTheme()
    const transitionMode = getThemeTransitionMode(theme)
    const restoreTransitions = disableThemeTransitions()
    const snapshot = createThemeSnapshot(currentTheme)
    const transitionState = { cancelled: false }
    const finalize = registerThemeTransitionCleanup(() => {
      transitionState.cancelled = true
      snapshot.remove()
      restoreTransitions()
    })

    applyTheme(theme)

    animateSnapshotReveal(
      snapshot,
      origin,
      followPointer,
      lockedPointer,
      transitionMode,
      transitionState,
    )
      .catch(() => {})
      .finally(finalize)
  }

  function handleThemeToggleClick(button, event) {
    if (themeWindow.__themeTransitionRunning) {
      cancelRunningThemeTransition()
    }

    const newTheme = getCurrentTheme() === 'dark' ? 'light' : 'dark'
    if (!canAnimateThemeTransition()) {
      applyThemeWithoutTransitions(newTheme)
      return
    }

    const lockedPointer = getButtonCenter(button)
    const followPointer = SHOULD_FOLLOW_POINTER
    const origin = followPointer
      ? getPointerOrigin(button, event)
      : lockedPointer

    setLastPointer(origin)

    themeWindow.__themeTransitionRunning = true

    if (!followPointer && canUseViewTransition()) {
      runThemeViewTransition(newTheme, origin)
      return
    }

    runThemeTransition(newTheme, origin, followPointer, lockedPointer)
  }

  function initThemeToggle() {
    if (themeWindow.__themeToggleInitialized) return

    themeWindow.__themeToggleInitialized = true

    setLastPointer(getViewportCenter())

    document.addEventListener('pointermove', (event) => {
      setLastPointer({ x: event.clientX, y: event.clientY })
    })

    document.addEventListener('click', (event) => {
      const target = event.target
      if (!(target instanceof Element)) return

      const button = target.closest(THEME_TOGGLE_SELECTOR)
      if (!(button instanceof HTMLElement)) return

      handleThemeToggleClick(button, event)
    })

    document.addEventListener('astro:after-swap', () => {
      syncTheme()
    })
  }

  initThemeToggle()
</script>
