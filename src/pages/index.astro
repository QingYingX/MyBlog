---
import BlogCard from '@/components/blog-card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import SocialIcons from '@/components/social-icons.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE, SOCIAL_LINKS } from '@/config'
import { getAllPosts, getAllTags, getRecentPosts } from '@/lib/data-utils'
import Layout from '@/layouts/layout.astro'
import { getEntry } from 'astro:content'
import { Icon } from 'astro-icon/components'

const recentPosts = await getRecentPosts(SITE.featuredPostCount)
const allPosts = await getAllPosts()
const allTags = await getAllTags()
const author = await getEntry('authors', 'qingyingx')

const earliestPost = allPosts.reduce<Date | null>((earliest, post) => {
  if (!earliest || post.data.date < earliest) return post.data.date
  return earliest
}, null)
const siteDays = earliestPost
  ? Math.max(
      1,
      Math.ceil(
        (Date.now() - earliestPost.valueOf()) / (1000 * 60 * 60 * 24),
      ),
    )
  : 1

const stats = [
  { label: '文章', value: allPosts.length },
  { label: '标签', value: allTags.size },
  { label: '建站', value: `${siteDays} 天` },
]
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="首页" />

  <section class="overflow-hidden rounded-2xl border">
    <div
      class="flex flex-col gap-6 p-6 sm:flex-row sm:items-center sm:gap-8 sm:p-8"
    >
      {
        author && (
          <img
            src={author.data.avatar}
            alt={author.data.name}
            width={112}
            height={112}
            class="ring-border size-24 shrink-0 rounded-full object-cover ring-2 sm:size-28"
            loading="eager"
          />
        )
      }

      <div class="flex min-w-0 flex-1 flex-col gap-3">
        <div class="flex flex-col gap-1">
          <p
            class="text-muted-foreground text-xs font-medium tracking-[0.24em] uppercase"
          >
            {SITE.title}
          </p>
          <h1 class="text-3xl leading-none font-medium sm:text-4xl">
            {author?.data.name ?? SITE.author}
          </h1>
          <p class="text-muted-foreground mt-1 text-sm">
            {author?.data.bio ?? '一名普普通通的学生'}
          </p>
        </div>

        <div class="flex flex-wrap items-center gap-2">
          <SocialIcons links={SOCIAL_LINKS} />
          <Link
            href="/about"
            class={buttonVariants({ variant: 'outline', size: 'sm' }) +
              ' group'}
          >
            了解更多
            <span class="ml-1 transition-transform group-hover:translate-x-0.5">
              &rarr;
            </span>
          </Link>
        </div>
      </div>
    </div>

    <div
      class="grid grid-cols-3 divide-x border-t text-center text-sm"
    >
      {
        stats.map((stat) => (
          <div class="flex flex-col gap-0.5 px-4 py-3">
            <span class="text-foreground text-lg font-medium tabular-nums">
              {stat.value}
            </span>
            <span class="text-muted-foreground text-xs">{stat.label}</span>
          </div>
        ))
      }
    </div>

    <div
      class="bg-muted/40 text-muted-foreground flex items-start gap-2 border-t px-6 py-3 text-xs"
      data-hitokoto
      aria-live="polite"
    >
      <Icon name="lucide:message-square-quote" class="mt-0.5 size-4 shrink-0" />
      <div class="min-w-0 flex-1">
        <p class="leading-relaxed" data-hitokoto-text>正在获取一言……</p>
        <p
          class="text-muted-foreground/80 mt-1 text-right empty:hidden"
          data-hitokoto-from
        >
        </p>
      </div>
    </div>
  </section>

  <section class="flex flex-col gap-y-4">
    <div class="flex items-end justify-between gap-2">
      <h2 class="text-2xl font-medium">最新文章</h2>
      <Link
        href="/blog"
        class="text-muted-foreground hover:text-foreground group inline-flex items-center gap-1 text-sm transition-colors"
      >
        查看全部
        <span class="transition-transform group-hover:translate-x-0.5">
          &rarr;
        </span>
      </Link>
    </div>
    <ul class="flex flex-col gap-y-4">
      {
        recentPosts.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href="/blog"
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        来看看清影的其他文章吧~
        <span class="ml-1.5 transition-transform group-hover:translate-x-1">
          &rarr;
        </span>
      </Link>
    </div>
  </section>
</Layout>

<script>
  type Hitokoto = {
    hitokoto: string
    from?: string
    from_who?: string | null
  }

  const STORAGE_KEY = 'hitokoto-cache-v1'
  const TTL = 60 * 60 * 1000 // 1 小时

  type Cached = { data: Hitokoto; at: number }

  function readCache(): Hitokoto | null {
    try {
      const raw = localStorage.getItem(STORAGE_KEY)
      if (!raw) return null
      const parsed = JSON.parse(raw) as Cached
      if (Date.now() - parsed.at > TTL) return null
      return parsed.data
    } catch {
      return null
    }
  }

  function writeCache(data: Hitokoto) {
    try {
      localStorage.setItem(
        STORAGE_KEY,
        JSON.stringify({ data, at: Date.now() } satisfies Cached),
      )
    } catch {
      // 忽略 localStorage 写入失败（例如隐私模式）
    }
  }

  function render(data: Hitokoto) {
    const textEl = document.querySelector('[data-hitokoto-text]')
    const fromEl = document.querySelector('[data-hitokoto-from]')
    if (!(textEl instanceof HTMLElement) || !(fromEl instanceof HTMLElement))
      return

    const fromBook = data.from?.trim() ? `《${data.from.trim()}》` : ''
    const fromWho = data.from_who?.trim() ?? ''
    const signature = [fromBook, fromWho].filter(Boolean).join(' ')

    textEl.textContent = data.hitokoto
    fromEl.textContent = signature ? `—— ${signature}` : ''
  }

  async function loadHitokoto() {
    const cached = readCache()
    if (cached) {
      render(cached)
      return
    }

    try {
      const res = await fetch('https://v1.hitokoto.cn', { cache: 'no-store' })
      if (!res.ok) throw new Error(`HTTP ${res.status}`)
      const data = (await res.json()) as Hitokoto
      render(data)
      writeCache(data)
    } catch (error) {
      console.error('[hitokoto] 获取失败：', error)
      const textEl = document.querySelector('[data-hitokoto-text]')
      if (textEl instanceof HTMLElement) {
        textEl.textContent = '一言加载失败，稍后再试'
      }
    }
  }

  document.addEventListener('astro:page-load', loadHitokoto)
</script>
