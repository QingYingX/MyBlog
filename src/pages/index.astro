---
import BlogCard from '@/components/blog-card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE } from '@/config'
import Layout from '@/layouts/layout.astro'
import { getRecentPosts } from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'

const blog = await getRecentPosts(SITE.featuredPostCount)
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="首页" />
  <section class="overflow-hidden rounded-lg border">
    <div class="flex flex-col space-y-1.5 p-6">
      <h3 class="text-3xl leading-none font-medium">QingYingX's Blog</h3>
    </div>
    <div class="px-6 pb-6">
      <p class="text-muted-foreground text-sm">一名普普通通的学生</p>
    </div>
    <div
      class="bg-muted/40 text-muted-foreground flex items-start gap-2 border-t px-6 py-3 text-xs"
      data-hitokoto
      aria-live="polite"
    >
      <Icon name="lucide:message-square-quote" class="mt-0.5 size-4 shrink-0" />
      <div class="min-w-0 flex-1">
        <p class="leading-relaxed" data-hitokoto-text>正在获取一言……</p>
        <p
          class="text-muted-foreground/80 mt-1 text-right empty:hidden"
          data-hitokoto-from
        ></p>
      </div>
    </div>
  </section>
  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">最新文章</h2>
    <ul class="flex flex-col gap-y-4">
      {
        blog.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href="/blog"
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        来看看清影的其他文章吧~ <span
          class="ml-1.5 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
  </section>
</Layout>

<script>
  type Hitokoto = {
    hitokoto: string
    from?: string
    from_who?: string | null
  }

  const STORAGE_KEY = 'hitokoto-cache-v1'
  const TTL = 60 * 60 * 1000 // 1 小时

  type Cached = { data: Hitokoto; at: number }

  function readCache(): Hitokoto | null {
    try {
      const raw = localStorage.getItem(STORAGE_KEY)
      if (!raw) return null
      const parsed = JSON.parse(raw) as Cached
      if (Date.now() - parsed.at > TTL) return null
      return parsed.data
    } catch {
      return null
    }
  }

  function writeCache(data: Hitokoto) {
    try {
      localStorage.setItem(
        STORAGE_KEY,
        JSON.stringify({ data, at: Date.now() } satisfies Cached),
      )
    } catch {
      // 忽略 localStorage 写入失败（例如隐私模式）
    }
  }

  function render(data: Hitokoto) {
    const textEl = document.querySelector('[data-hitokoto-text]')
    const fromEl = document.querySelector('[data-hitokoto-from]')
    if (!(textEl instanceof HTMLElement) || !(fromEl instanceof HTMLElement))
      return

    const fromBook = data.from?.trim() ? `《${data.from.trim()}》` : ''
    const fromWho = data.from_who?.trim() ?? ''
    const signature = [fromBook, fromWho].filter(Boolean).join(' ')

    textEl.textContent = data.hitokoto
    fromEl.textContent = signature ? `—— ${signature}` : ''
  }

  async function loadHitokoto() {
    const cached = readCache()
    if (cached) {
      render(cached)
      return
    }

    try {
      const res = await fetch('https://v1.hitokoto.cn', { cache: 'no-store' })
      if (!res.ok) throw new Error(`HTTP ${res.status}`)
      const data = (await res.json()) as Hitokoto
      render(data)
      writeCache(data)
    } catch (error) {
      console.error('[hitokoto] 获取失败：', error)
      const textEl = document.querySelector('[data-hitokoto-text]')
      if (textEl instanceof HTMLElement) {
        textEl.textContent = '一言加载失败，稍后再试'
      }
    }
  }

  document.addEventListener('astro:page-load', loadHitokoto)
</script>
