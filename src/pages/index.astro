---
import BlogCard from '@/components/blog-card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE } from '@/consts'
import Layout from '@/layouts/layout.astro'
import { getRecentPosts } from '@/lib/data-utils'

const blog = await getRecentPosts(SITE.featuredPostCount)
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="首页" />
  <section class="rounded-lg border">
    <div class="flex flex-col space-y-1.5 p-6">
      <h3 class="text-3xl leading-none font-medium">青萤博客</h3>
      <p class="text-muted-foreground text-sm">内容优先 · 轻量静态 · 易于定制</p>
    </div>
    <div class="p-6 pt-0">
      <p class="text-muted-foreground mb-2 text-sm">
        这是一个基于 <Link
          href="https://astro.build"
          class="text-foreground"
          external
          underline>Astro</Link
        >, <Link
          href="https://tailwindcss.com"
          class="text-foreground"
          external
          underline>Tailwind</Link
        > 和 <Link
          href="https://ui.shadcn.com"
          class="text-foreground"
          external
          underline>shadcn/ui</Link
        > 构建的中文静态博客模板，适合用来整理文章、笔记和项目内容，也方便在现有基础上继续做个性化改造。
      </p>
      <p class="text-muted-foreground text-sm">
        当前项目已经切换到你自己的仓库。你可以先查看 <Link
          href="https://github.com/QingYingX/MyBlog"
          class="text-foreground"
          underline
          external>GitHub 仓库</Link
        >，也可以继续阅读这篇文章了解模板的设计思路：<Link
          href="/blog/the-state-of-static-blogs"
          class="text-foreground"
          underline>2024 年静态博客现状观察</Link
        >。
      </p>
      <p class="text-muted-foreground mt-2 text-sm">
        如果你想保留原主题的灵感来源，也可以看看 <Link
          href="https://astro-micro.vercel.app/"
          class="text-foreground"
          external
          underline>Astro Micro</Link
        >。
      </p>
    </div>
  </section>
  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">最新文章</h2>
    <ul class="flex flex-col gap-y-4">
      {
        blog.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href="/blog"
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        查看全部文章 <span
          class="ml-1.5 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
  </section>
</Layout>
